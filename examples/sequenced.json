{
  "id": "sequenced-job",
  "root": {
    "id": "root",
    "uses": "builtins/sequence",
    "steps": [
      {
        "id": "step-1",
        "uses": "builtins/script",
        "with": {
          "script": "echo 'Hello from Vectis!'"
        }
      },
      {
        "id": "step-2",
        "uses": "builtins/script",
        "with": {
          "script": "echo 'Running multiple steps in sequence'"
        }
      },
      {
        "id": "step-3",
        "uses": "builtins/script",
        "with": {
          "runner": "sh",
          "script": "pwd && ls -la"
        }
      }
    ]
  }
}
