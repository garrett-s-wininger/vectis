{
  "id": "parallel-job",
  "root": {
    "id": "root",
    "uses": "builtins/sequence",
    "with": {
      "execution": "local"
    },
    "ports": {
      "steps": {
        "nodes": [
          {
            "id": "setup",
            "uses": "builtins/shell",
            "with": {
              "command": "echo 'Preparing workspace'"
            }
          },
          {
            "id": "checks",
            "uses": "builtins/parallel",
            "with": {
              "execution": "distributed"
            },
            "ports": {
              "branches": {
                "nodes": [
                  {
                    "id": "unit-tests",
                    "uses": "builtins/shell",
                    "with": {
                      "command": "echo 'Running unit tests'"
                    }
                  },
                  {
                    "id": "lint",
                    "uses": "builtins/shell",
                    "with": {
                      "command": "echo 'Running lint'"
                    }
                  }
                ]
              }
            }
          },
          {
            "id": "finish",
            "uses": "builtins/shell",
            "with": {
              "command": "echo 'All checks complete'"
            }
          }
        ]
      }
    }
  }
}
