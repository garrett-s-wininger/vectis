{
  "id": "secret-example",
  "secrets": [
    {
      "id": "smoke-token",
      "ref": "encryptedfs://team/smoke-token",
      "delivery": {
        "type": "file",
        "path": "smoke/token"
      },
      "task_keys": ["verify-secret"]
    }
  ],
  "root": {
    "id": "verify-secret",
    "uses": "builtins/script",
    "with": {
      "runner": "sh",
      "script": "test -n \"$VECTIS_SECRETS_DIR\" && test \"$(cksum < \"$VECTIS_SECRETS_DIR/smoke/token\")\" = \"2931055294 13\""
    }
  }
}
