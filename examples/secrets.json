{
  "id": "secret-example",
  "secrets": [
    {
      "id": "smoke-token",
      "ref": "encryptedfs://team/smoke-token",
      "delivery": {
        "type": "file",
        "path": "smoke/token"
      },
      "task_keys": ["verify-secret"]
    }
  ],
  "root": {
    "id": "verify-secret",
    "uses": "builtins/shell",
    "with": {
      "command": "test -n \"$VECTIS_SECRETS_DIR\" && test \"$(cat \"$VECTIS_SECRETS_DIR/smoke/token\")\" = local-spiffe-secret"
    }
  }
}
