{
  "name": "vectis-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "storybook": "mkdir -p .cache/storybook-home && HOME=$PWD/.cache/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --ci --no-open --initial-path='/?path=/story/components-layout-appshell--dashboard'",
    "storybook:build": "mkdir -p .cache/storybook-home && HOME=$PWD/.cache/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build --disable-telemetry",
    "storybook:smoke": "mkdir -p .cache/storybook-home && HOME=$PWD/.cache/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6101 --ci --no-open",
    "dev:smoke": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "format": "prettier --write \"src/**/*.{css,ts,tsx}\" \"smoke/**/*.ts\" \".storybook/**/*.ts\" \"mock/**/*.{css,html}\" \"*.{html,js,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{css,ts,tsx}\" \"smoke/**/*.ts\" \".storybook/**/*.ts\" \"mock/**/*.{css,html}\" \"*.{html,js,json,ts}\"",
    "lint": "eslint -c eslint.config.js \"src/**/*.{ts,tsx}\" \"smoke/**/*.ts\" \".storybook/**/*.ts\" \"*.{js,ts}\" && stylelint \"src/**/*.css\" \"mock/**/*.css\"",
    "smoke": "env -u NO_COLOR PLAYWRIGHT_BROWSERS_PATH=$PWD/node_modules/.cache/ms-playwright playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
