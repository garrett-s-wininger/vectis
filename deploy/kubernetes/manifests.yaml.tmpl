---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vectis-worker
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: worker
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vectis
      app.kubernetes.io/component: worker
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vectis
        app.kubernetes.io/component: worker
    spec:
      automountServiceAccountToken: false
      initContainers:
        - name: db-migrate
          image: {{ image "cli" }}
          imagePullPolicy: IfNotPresent
          args: ["database", "migrate"]
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
      containers:
        - name: worker-core
          image: {{ image "worker-core" }}
          imagePullPolicy: IfNotPresent
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_WORKER_CORE_SOCKET
              value: /run/vectis/worker-core/worker-core.sock
            - name: VECTIS_WORKER_CORE_WORKSPACE_ROOT
              value: /workspace
          volumeMounts:
            - name: worker-core-sockets
              mountPath: /run/vectis/worker-core
            - name: worker-workspace
              mountPath: /workspace
        - name: worker
          image: {{ image "worker" }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: control
              containerPort: 9084
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
            - name: VECTIS_WORKER_CORE_SOCKET
              value: /run/vectis/worker-core/worker-core.sock
            - name: VECTIS_WORKER_CORE_SHELL_SOCKET
              value: /run/vectis/worker-core/worker-core-shell.sock
            - name: VECTIS_WORKER_SECRETS_ADDRESS
              value: vectis-secrets:8090
            - name: VECTIS_WORKER_REGISTER_WITH_REGISTRY
              value: "false"
          volumeMounts:
            - name: worker-core-sockets
              mountPath: /run/vectis/worker-core
            - name: worker-workspace
              mountPath: /workspace
      volumes:
        - name: worker-core-sockets
          emptyDir: {}
        - name: worker-workspace
          emptyDir: {}
