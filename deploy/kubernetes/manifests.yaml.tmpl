apiVersion: v1
kind: Service
metadata:
  name: vectis-postgres
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: postgres
spec:
  selector:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: postgres
  ports:
    - name: postgres
      port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: vectis-postgres
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: postgres
spec:
  serviceName: vectis-postgres
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vectis
      app.kubernetes.io/component: postgres
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vectis
        app.kubernetes.io/component: postgres
    spec:
      automountServiceAccountToken: false
      containers:
        - name: postgres
          image: docker.io/library/postgres:18-alpine
          imagePullPolicy: IfNotPresent
          ports:
            - name: postgres
              containerPort: 5432
          env:
            - name: POSTGRES_USER
              value: vectis
            - name: POSTGRES_DB
              value: vectis
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: POSTGRES_PASSWORD
          volumeMounts:
            - name: postgres-data
              mountPath: /var/lib/postgresql
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "vectis", "-d", "vectis"]
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            exec:
              command: ["pg_isready", "-U", "vectis", "-d", "vectis"]
            initialDelaySeconds: 20
            periodSeconds: 10
      volumes:
        - name: postgres-data
          persistentVolumeClaim:
            claimName: vectis-postgres-data
---
