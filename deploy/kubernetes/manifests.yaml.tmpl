apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: vectis-secrets
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: secrets
spec:
  serviceName: vectis-secrets
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vectis
      app.kubernetes.io/component: secrets
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vectis
        app.kubernetes.io/component: secrets
    spec:
      automountServiceAccountToken: false
      initContainers:
        - name: db-migrate
          image: {{ image "cli" }}
          imagePullPolicy: IfNotPresent
          args: ["database", "migrate"]
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
      containers:
        - name: secrets
          image: {{ image "secrets" }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: grpc
              containerPort: 8090
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
            - name: VECTIS_SECRETS_ENCRYPTEDFS_ROOT
              value: /data/vectis/secrets/encryptedfs
            - name: VECTIS_SECRETS_ENCRYPTEDFS_KEY_FILE
              value: /run/vectis/secrets/encryptedfs.key
            - name: VECTIS_SECRETS_POLICY_ALLOW
              value: "namespace=*;job=*;task=*;ref=encryptedfs://*"
          volumeMounts:
            - name: secrets-data
              mountPath: /data/vectis/secrets
            - name: secrets-key
              mountPath: /run/vectis/secrets
              readOnly: true
          readinessProbe:
            grpc:
              port: 8090
            initialDelaySeconds: 3
            periodSeconds: 5
          livenessProbe:
            grpc:
              port: 8090
            initialDelaySeconds: 10
            periodSeconds: 10
      volumes:
        - name: secrets-data
          persistentVolumeClaim:
            claimName: vectis-secrets-data
        - name: secrets-key
          secret:
            secretName: vectis-secrets
            items:
              - key: encryptedfs.key
                path: encryptedfs.key
