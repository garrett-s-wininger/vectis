metadata:
  name: vectis-api
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: api
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vectis
      app.kubernetes.io/component: api
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vectis
        app.kubernetes.io/component: api
    spec:
      automountServiceAccountToken: false
      initContainers:
        - name: db-migrate
          image: {{ image "cli" }}
          imagePullPolicy: IfNotPresent
          args: ["database", "migrate"]
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
      containers:
        - name: api
          image: {{ image "api" }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8080
          envFrom:
            - configMapRef:
                name: vectis-env
          env:
            - name: VECTIS_API_SERVER_HOST
              value: 0.0.0.0
            - name: VECTIS_API_SERVER_PORT
              value: "8080"
            - name: VECTIS_DATABASE_DSN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_DATABASE_DSN
            - name: VECTIS_API_AUTH_BOOTSTRAP_TOKEN
              valueFrom:
                secretKeyRef:
                  name: vectis-secrets
                  key: VECTIS_API_AUTH_BOOTSTRAP_TOKEN
          readinessProbe:
            httpGet:
              path: /health/ready
              port: 8080
              httpHeaders:
                - name: Host
                  value: localhost
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /health/live
              port: 8080
              httpHeaders:
                - name: Host
                  value: localhost
            initialDelaySeconds: 10
            periodSeconds: 10
