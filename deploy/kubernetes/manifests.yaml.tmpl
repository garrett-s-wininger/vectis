apiVersion: v1
kind: Namespace
metadata:
  name: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/part-of: vectis
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: vectis-env
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/part-of: vectis
data:
  VECTIS_CELL_ID: local
  VECTIS_DATABASE_DRIVER: pgx
  VECTIS_DISCOVERY_REGISTRY_ADDRESS: vectis-registry:8082
  VECTIS_GRPC_TLS_INSECURE: "true"
  VECTIS_METRICS_TLS_INSECURE: "true"
  VECTIS_LOG_FORMAT: json
  VECTIS_LOG_DIR: /var/log/vectis
  VECTIS_API_SERVER_LOG_FORMAT: json
  VECTIS_WORKER_EXECUTION_IDENTITY_ENABLED: "true"
  VECTIS_WORKER_EXECUTION_IDENTITY_TRUST_DOMAIN: vectis.internal
  VECTIS_API_ALLOWED_HOSTS: "localhost,127.0.0.1,vectis-api,vectis-api.{{ .Namespace }}.svc,vectis-api.{{ .Namespace }}.svc.cluster.local"
  VECTIS_DOCS_ALLOWED_HOSTS: "localhost,127.0.0.1,vectis-docs,vectis-docs.{{ .Namespace }}.svc,vectis-docs.{{ .Namespace }}.svc.cluster.local"
---
apiVersion: v1
kind: Secret
metadata:
  name: vectis-secrets
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/part-of: vectis
type: Opaque
stringData:
  POSTGRES_PASSWORD: {{ yamlQuote .PostgresPassword }}
  VECTIS_DATABASE_DSN: {{ yamlQuote .DatabaseDSN }}
  VECTIS_API_AUTH_BOOTSTRAP_TOKEN: {{ yamlQuote .BootstrapToken }}
  encryptedfs.key: {{ yamlQuote .EncryptedFSKey }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: vectis-postgres-data
  namespace: {{ yamlQuote .Namespace }}
  labels:
    app.kubernetes.io/name: vectis
    app.kubernetes.io/component: postgres
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
