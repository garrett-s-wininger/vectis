# syntax=docker/dockerfile:1
FROM docker.io/library/node:26-alpine AS docs-builder
WORKDIR /app/website
COPY website/package.json website/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci
COPY website/ ./
RUN npm run build

FROM docker.io/library/golang:1.25.10-alpine AS builder
RUN apk add --no-cache make

WORKDIR /app
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download && go mod verify

COPY api/ ./api/
COPY cmd/ ./cmd/
COPY deploy/podman/ ./deploy/podman/
COPY internal/ ./internal/
COPY Makefile ./Makefile
COPY --from=docs-builder /app/website/build ./cmd/docs/embedded

ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    make -j"$(getconf _NPROCESSORS_ONLN)" build-container SKIP_DOCS_ASSETS=1

FROM scratch AS api
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-api /usr/local/bin/vectis-api
ENTRYPOINT ["/usr/local/bin/vectis-api"]

FROM scratch AS artifact
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-artifact /usr/local/bin/vectis-artifact
ENTRYPOINT ["/usr/local/bin/vectis-artifact"]

