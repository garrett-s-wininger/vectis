FROM scratch AS all-in-one
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
ENV XDG_DATA_HOME=/data
ENV VECTIS_LOCAL_HOST=0.0.0.0
COPY --from=builder \
      /app/bin/vectis-api \
      /app/bin/vectis-artifact \
      /app/bin/vectis-catalog \
      /app/bin/vectis-cell-ingress \
      /app/bin/vectis-cron \
      /app/bin/vectis-docs \
      /app/bin/vectis-local \
      /app/bin/vectis-spiffe \
      /app/bin/vectis-log \
      /app/bin/vectis-log-forwarder \
      /app/bin/vectis-orchestrator \
      /app/bin/vectis-queue \
      /app/bin/vectis-reconciler \
      /app/bin/vectis-registry \
      /app/bin/vectis-secrets \
      /app/bin/vectis-worker-core \
      /app/bin/vectis-worker \
      /usr/local/bin/
ENTRYPOINT ["/usr/local/bin/vectis-local"]
