# syntax=docker/dockerfile:1
FROM docker.io/library/golang:1.25.7-alpine AS builder
RUN apk add --no-cache make

WORKDIR /app
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download && go mod verify

COPY api/ ./api/
COPY cmd/ ./cmd/
COPY internal/ ./internal/
COPY Makefile ./Makefile

ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    make -j"$(getconf _NPROCESSORS_ONLN)" build-container

FROM scratch AS api
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-api /usr/local/bin/vectis-api
ENTRYPOINT ["/usr/local/bin/vectis-api"]

FROM scratch AS cli
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-cli /usr/local/bin/vectis-cli
ENTRYPOINT ["/usr/local/bin/vectis-cli"]

FROM scratch as cron
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-cron /usr/local/bin/vectis-cron
ENTRYPOINT ["/usr/local/bin/vectis-cron"]

FROM scratch as log
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-log /usr/local/bin/vectis-log
ENTRYPOINT ["/usr/local/bin/vectis-log"]

FROM scratch AS queue
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-queue /usr/local/bin/vectis-queue
ENTRYPOINT ["/usr/local/bin/vectis-queue"]

FROM scratch AS reconciler
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-reconciler /usr/local/bin/vectis-reconciler
ENTRYPOINT ["/usr/local/bin/vectis-reconciler"]

FROM scratch AS registry
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
COPY --from=builder /app/bin/vectis-registry /usr/local/bin/vectis-registry
ENTRYPOINT ["/usr/local/bin/vectis-registry"]

FROM docker.io/library/alpine:3.23 AS worker
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/bin/vectis-worker /usr/local/bin/vectis-worker
ENTRYPOINT ["/usr/local/bin/vectis-worker"]

FROM scratch AS all-in-one
LABEL org.opencontainers.image.source="https://github.com/garrett-s-wininger/vectis" \
      org.opencontainers.image.authors="Garrett Wininger <garrett.s.wininger@outlook.com>"
ENV XDG_DATA_HOME=/data
COPY --from=builder \
      /app/bin/vectis-api \
      /app/bin/vectis-cron \
      /app/bin/vectis-local \
      /app/bin/vectis-log \
      /app/bin/vectis-queue \
      /app/bin/vectis-reconciler \
      /app/bin/vectis-registry \
      /app/bin/vectis-worker \
      /usr/local/bin/
ENTRYPOINT ["/usr/local/bin/vectis-local"]
